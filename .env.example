# Supabase Configuration
# These are PUBLIC variables (prefixed with NEXT_PUBLIC_)
# Get these values from your Supabase project settings at: https://app.supabase.com

# Your Supabase project URL
# Format: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous/public key (safe to expose)
# This is NOT a secret - it's specifically designed for public client-side access
# Get it from: Project Settings > API > Project URL and anon key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
